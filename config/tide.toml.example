[shell]
program = "zsh"

[ui.transitions]
enabled = true
duration_ms = 220
fps = 30
skip_if_fast_under_ms = 80
reduced_motion = false

[blocks]
max_output_bytes_per_block = 1048576
strip_ansi_for_text = true
persist_session = false

[history]
max_blocks = 1000

[block_view]
preview_lines = 4
expanded_lines = 15
follow_tail = true
block_gap = 0
scroll_margin_blocks = 2
scroll_margin_lines = 2
auto_follow_on_reach_bottom = false
horizontal_margin = 1
body_padding = 1
show_footer = true
# Clipboard serialization format: plaintext | markdown | shell_transcript | json
copy_format = "plaintext"

[block_layout]
horizontal_padding = 1
show_padding_in_plain = true

# Classification is an exception list. Commands not listed here are normal:
# Tide captures their linear output into ordinary command blocks.
[classification.tui]
commands = [
  "vim", "nvim", "vi", "nano", "helix", "hx", "less", "more", "bat", "batcat",
  "fzf", "skim", "sk",
  "yazi", "ya", "ranger", "nnn", "lf", "mc", "vifm",
  "lazygit", "tig", "gitui", "serie", "lazyjj",
  "lazydocker", "k9s", "kubectl-neat", "ctop", "lazysql",
  "top", "htop", "btop", "bottom", "btm", "glances", "nmon", "iotop", "iftop", "nvtop",
  "tmux", "screen", "zellij",
  "watch", "viddy", "posting",
]

[classification.repl]
commands = [
  "python", "python3", "ipython", "bpython", "ptpython",
  "node", "deno", "bun", "tsx",
  "psql", "sqlite3", "mysql", "mariadb", "redis-cli", "mongosh", "duckdb", "clickhouse-client",
  "ruby", "irb", "pry", "php", "phpdbg", "lua", "luajit", "R", "Rscript", "julia",
  "ghci", "scala", "sbt", "clojure", "lein", "iex", "erl", "erlc", "swipl", "gdb", "lldb",
  "bash", "zsh", "fish", "xonsh", "nu", "powershell", "pwsh",
]

[classification.agent]
commands = [
  "codex", "claude", "gemini",
  "opencode", "aider", "crush", "goose", "amp", "codebuff", "cursor-agent",
  "copilot", "gh-copilot",
  "qwen", "qwen-code",
  "ollama", "llm", "mods", "sgpt", "fabric",
]

# Key bindings — single-byte keys only. Multi-byte sequences (arrows, Ctrl-chords)
# stay hardcoded. Action name is the key, value is the character string.
# Uncomment and change to remap:
# [keymap.blocks]
# nav_down = "j"   # default
# nav_up = "k"     # default
# nav_bottom = "G" # default
# nav_top = "g"    # default
# scroll_half_up = "ë"        # Ctrl-U
# scroll_half_down = "ä"      # Ctrl-D
# scroll_full_up = "â"        # Ctrl-B
# scroll_full_down = "æ"      # Ctrl-F
# expand = "ï"                # Enter
# detail_view = "i"  # default
# toggle_failed_filter = "f"  # default
# open_search = "/"  # default
# copy_command = "c" # default
# copy_output = "o"  # default
# copy_both = "y"    # default
# rerun = "r"        # default
# delete = "d"       # default
# visual_mode = "v"  # default
# search_next = "n"  # default
# search_prev = "N"  # default
# help = "?"         # default
# quit = "q"         # default

# [keymap.detail]
# nav_down = "j"   # default
# nav_up = "k"     # default
# nav_bottom = "G" # default
# nav_top = "g"    # default
# copy_command = "c" # default
# copy_output = "o"  # default
# copy_both = "y"    # default
# rerun = "r"        # default
# visual_mode = "v"  # default
# help = "?"         # default
# quit = "q"         # default
