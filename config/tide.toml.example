[shell]
program = "zsh"

[ui.transitions]
enabled = true
duration_ms = 220
fps = 30
skip_if_fast_under_ms = 80
reduced_motion = false

[blocks]
max_output_bytes_per_block = 1048576
strip_ansi_for_text = true
persist_session = false

[history]
max_blocks = 1000

[block_view]
preview_lines = 4
expanded_lines = 15
follow_tail = true
block_gap = 0
scroll_margin_blocks = 2
scroll_margin_lines = 2
auto_follow_on_reach_bottom = false
horizontal_margin = 1
body_padding = 1
show_footer = true
# Clipboard serialization format: plaintext | markdown | shell_transcript | json
copy_format = "plaintext"

[block_layout]
horizontal_padding = 1
show_padding_in_plain = true

# Legacy compatibility field. Current Normal mode is transparent passthrough,
# so this is not required for vim/yazi/fzf/less/ssh/etc. to work.
raw_programs = [
  "my-tui-app",
  "lg",
  "v",
]

[tui_apps.nvim]
commands = ["nvim", "vim"]
handoff = true
snapshot = ["git", "cwd"]
return_panel = "changed-files"

[tui_apps.lazygit]
commands = ["lazygit"]
handoff = true
snapshot = ["git"]
after_exit = ["git status --short"]
return_panel = "git"

[tui_apps.opencode]
commands = ["opencode"]
handoff = true
snapshot = ["git", "cwd"]
after_exit = ["git status --short", "git diff --stat"]
return_panel = "summary"

[tui_apps.fzf]
commands = ["fzf"]
handoff = true
return_panel = "none"

[tui_apps.less]
commands = ["less"]
handoff = true
return_panel = "none"

# Key bindings — single-byte keys only. Multi-byte sequences (arrows, Ctrl-chords)
# stay hardcoded. Action name is the key, value is the character string.
# Uncomment and change to remap:
# [keymap.blocks]
# nav_down = "j"   # default
# nav_up = "k"     # default
# nav_bottom = "G" # default
# nav_top = "g"    # default
# scroll_half_up = "ë"        # Ctrl-U
# scroll_half_down = "ä"      # Ctrl-D
# scroll_full_up = "â"        # Ctrl-B
# scroll_full_down = "æ"      # Ctrl-F
# expand = "ï"                # Enter
# detail_view = "i"  # default
# toggle_failed_filter = "f"  # default
# open_search = "/"  # default
# copy_command = "c" # default
# copy_output = "o"  # default
# copy_both = "y"    # default
# rerun = "r"        # default
# delete = "d"       # default
# visual_mode = "v"  # default
# search_next = "n"  # default
# search_prev = "N"  # default
# help = "?"         # default
# quit = "q"         # default

# [keymap.detail]
